<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="using:DataProtectionTool"
             mc:Ignorable="d"
             d:DesignWidth="760"
             d:DesignHeight="560"
             x:Class="DataProtectionTool.ConnectionsWizard">
    <UserControl.Styles>
        <Style Selector="ListBox.entity-table-listbox">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Border.entity-table-row">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E0E8F2" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="ListBoxItem:selected Border.entity-table-row">
            <Setter Property="Background" Value="#DBE9FF" />
            <Setter Property="BorderBrush" Value="#4B78B1" />
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="2.2*,16,1.3*">
        <Grid Grid.Column="0"
              RowDefinitions="Auto,10,Auto,8,*">
            <Grid Grid.Row="0"
                  ColumnDefinitions="*,Auto">
                <TextBlock Text="Connections"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#0B2D5C" />
                <Button Grid.Column="1"
                        Content="Add New"
                        Padding="12,6"
                        Click="OnAddNewClicked" />
            </Grid>

            <Border Grid.Row="2"
                    Background="#0B2D5C"
                    CornerRadius="8"
                    Padding="16,10">
                <Grid ColumnDefinitions="1.6*,2.2*,1.2*"
                      ColumnSpacing="14">
                    <TextBlock Text="Name"
                               Foreground="White"
                               FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1"
                               Text="Endpoint"
                               Foreground="White"
                               FontWeight="SemiBold" />
                    <TextBlock Grid.Column="2"
                               Text="Type"
                               Foreground="White"
                               FontWeight="SemiBold" />
                </Grid>
            </Border>

            <Border Grid.Row="4"
                    BorderBrush="#D7E1EF"
                    BorderThickness="1"
                    CornerRadius="10"
                    Background="#F9FBFE"
                    Padding="10">
                <Grid>
                    <TextBlock x:Name="EmptyStateText"
                               Text="No connections yet. Click Add New to create one."
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#4C6388" />
                    <ListBox x:Name="ItemsListBox"
                             Classes="entity-table-listbox"
                             IsVisible="False"
                             SelectionChanged="OnItemSelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="local:ConnectionItem">
                                <Border Classes="entity-table-row"
                                        Margin="0,0,0,8"
                                        Padding="12,10"
                                        CornerRadius="6">
                                    <Grid ColumnDefinitions="1.6*,2.2*,1.2*"
                                          ColumnSpacing="14">
                                        <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="1" Text="{Binding Endpoint}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="2" Text="{Binding Type}" TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Column="2"
                BorderBrush="#D7E1EF"
                BorderThickness="1"
                CornerRadius="10"
                Background="White"
                Padding="14">
            <Grid RowDefinitions="Auto,12,Auto,8,Auto,8,Auto,8,Auto,16,Auto">
                <Grid ColumnDefinitions="*,8,Auto,8,Auto,8,Auto">
                    <TextBlock Text="Connection Details"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#0B2D5C" />
                    <Button x:Name="EditButton"
                            Grid.Column="2"
                            Content="Edit"
                            Padding="10,4"
                            Click="OnEditClicked" />
                    <Button x:Name="CopyButton"
                            Grid.Column="4"
                            Content="Copy"
                            Padding="10,4"
                            Click="OnCopyClicked" />
                    <Button x:Name="DeleteButton"
                            Grid.Column="6"
                            Content="Delete"
                            Padding="10,4"
                            Click="OnDeleteClicked" />
                </Grid>

                <TextBlock Grid.Row="2" Text="Name" Foreground="#4C6388" />
                <TextBox x:Name="NameTextBox" Grid.Row="3" Height="36" IsReadOnly="True" />
                <TextBlock Grid.Row="4" Text="Endpoint" Foreground="#4C6388" />
                <TextBox x:Name="EndpointTextBox" Grid.Row="5" Height="36" IsReadOnly="True" />
                <TextBlock Grid.Row="6" Text="Type" Foreground="#4C6388" />
                <TextBox x:Name="TypeTextBox" Grid.Row="7" Height="36" IsReadOnly="True" />
                <TextBlock Grid.Row="8" Text="Notes" Foreground="#4C6388" />
                <TextBox x:Name="NotesTextBox" Grid.Row="9" Height="72" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" />

                <Grid Grid.Row="10"
                      ColumnDefinitions="*,8,Auto,8,Auto">
                    <TextBlock x:Name="StatusText"
                               VerticalAlignment="Center"
                               Foreground="#4C6388" />
                    <Button x:Name="CancelEditButton"
                            Grid.Column="2"
                            Content="Cancel"
                            Padding="12,6"
                            IsVisible="False"
                            Click="OnCancelEditClicked" />
                    <Button x:Name="SaveButton"
                            Grid.Column="4"
                            Content="Save"
                            Padding="12,6"
                            IsVisible="False"
                            Background="#0B2D5C"
                            Foreground="White"
                            Click="OnSaveClicked" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
