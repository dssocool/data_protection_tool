<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="using:DataProtectionTool.Models"
             mc:Ignorable="d"
             d:DesignWidth="760"
             d:DesignHeight="560"
             x:Class="DataProtectionTool.Views.ConnectionsWizard">
    <UserControl.Styles>
        <Style Selector="ListBox.entity-table-listbox">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Border.entity-table-row">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E0E8F2" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="ListBoxItem:selected Border.entity-table-row">
            <Setter Property="Background" Value="#DBE9FF" />
            <Setter Property="BorderBrush" Value="#4B78B1" />
        </Style>
        <Style Selector="Button.connection-type-tab">
            <Setter Property="Background" Value="#EEF3FB" />
            <Setter Property="BorderBrush" Value="#CBD8EA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Foreground" Value="#0B2D5C" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="Button.connection-type-tab.selected">
            <Setter Property="Background" Value="#DBE9FF" />
            <Setter Property="BorderBrush" Value="#4B78B1" />
            <Setter Property="Foreground" Value="#0B2D5C" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,10,Auto,8,*">
            <Grid Grid.Row="0"
                  ColumnDefinitions="190,Auto,*">
                <TextBlock Text="Connections"
                           Grid.Column="0"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#0B2D5C" />
                <Button Grid.Column="1"
                        Content="Add New"
                        Padding="12,6"
                        Click="OnAddNewClicked" />
            </Grid>

            <Border Grid.Row="2"
                    Background="#0B2D5C"
                    CornerRadius="8"
                    Padding="16,10">
                <Grid ColumnDefinitions="2.4*,1.4*"
                      ColumnSpacing="14">
                    <TextBlock Text="Name"
                               Foreground="White"
                               FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1"
                               Text="Type"
                               Foreground="White"
                               FontWeight="SemiBold" />
                </Grid>
            </Border>

            <Border Grid.Row="4"
                    BorderBrush="#D7E1EF"
                    BorderThickness="1"
                    CornerRadius="10"
                    Background="#F9FBFE"
                    Padding="10">
                <Grid>
                    <TextBlock x:Name="EmptyStateText"
                               Text="No connections yet. Click Add New to create one."
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#4C6388" />
                    <ListBox x:Name="ItemsListBox"
                             Classes="entity-table-listbox"
                             IsVisible="False">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:ConnectionItem">
                                <Border Classes="entity-table-row"
                                        Margin="0,0,0,8"
                                        Padding="12,10"
                                        CornerRadius="6"
                                        PointerPressed="OnItemRowPressed">
                                    <Grid ColumnDefinitions="2.4*,1.4*"
                                          ColumnSpacing="14">
                                        <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="1" Text="{Binding Type}" TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        <Border x:Name="DetailsPanel"
                Grid.RowSpan="5"
                HorizontalAlignment="Right"
                VerticalAlignment="Stretch"
                Width="420"
                Margin="0,0,10,0"
                ZIndex="10"
                BorderBrush="#D7E1EF"
                BorderThickness="1"
                CornerRadius="10"
                Background="White"
                Padding="14"
                IsVisible="False">
            <Grid RowDefinitions="Auto,12,Auto,12,*,16,Auto">
                <Grid ColumnDefinitions="*,8,*,8,*">
                    <Button x:Name="SqlServerTabButton"
                            Grid.Column="0"
                            Classes="connection-type-tab"
                            Content="Microsoft SQL Server"
                            Click="OnSqlServerTabClicked" />
                    <Button x:Name="FabricTabButton"
                            Grid.Column="2"
                            Classes="connection-type-tab"
                            Content="Azure Fabric"
                            Click="OnFabricTabClicked" />
                    <Button x:Name="BlobTabButton"
                            Grid.Column="4"
                            Classes="connection-type-tab"
                            Content="Azure Blob Storage"
                            Click="OnBlobTabClicked" />
                </Grid>

                <Grid Grid.Row="2" ColumnDefinitions="*,8,Auto,8,Auto,8,Auto">
                    <TextBlock Text="Connection Details"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#0B2D5C" />
                    <Button x:Name="EditButton"
                            Grid.Column="2"
                            Content="Edit"
                            Padding="10,4"
                            Click="OnEditClicked" />
                    <Button x:Name="CopyButton"
                            Grid.Column="4"
                            Content="Copy"
                            Padding="10,4"
                            Click="OnCopyClicked" />
                    <Button x:Name="DeleteButton"
                            Grid.Column="6"
                            Content="Delete"
                            Padding="10,4"
                            Click="OnDeleteClicked" />
                </Grid>

                <ScrollViewer Grid.Row="4"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Name" Foreground="#4C6388" />
                        <TextBox x:Name="NameTextBox"
                                 Height="36"
                                 IsReadOnly="True"
                                 TextChanged="OnAnyInputChanged" />

                        <StackPanel x:Name="SqlFieldsPanel" Spacing="8">
                            <TextBlock Text="Server Name" Foreground="#4C6388" />
                            <TextBox x:Name="SqlServerNameTextBox"
                                     Height="36"
                                     IsReadOnly="True"
                                     TextChanged="OnAnyInputChanged" />
                            <TextBlock Text="Authentication Type" Foreground="#4C6388" />
                            <ComboBox x:Name="SqlAuthenticationComboBox"
                                      Height="36"
                                      IsEnabled="False"
                                      SelectionChanged="OnSqlAuthenticationChanged" />
                            <TextBlock Text="User Name" Foreground="#4C6388" />
                            <TextBox x:Name="SqlUserNameTextBox"
                                     Height="36"
                                     IsReadOnly="True"
                                     TextChanged="OnAnyInputChanged" />
                            <TextBlock Text="Password" Foreground="#4C6388" />
                            <TextBox x:Name="SqlPasswordBox"
                                     Height="36"
                                     IsReadOnly="True"
                                     PasswordChar="*"
                                     TextChanged="OnAnyInputChanged" />
                            <TextBlock Text="Database" Foreground="#4C6388" />
                            <TextBox x:Name="SqlDatabaseTextBox"
                                     Height="36"
                                     IsReadOnly="True"
                                     TextChanged="OnAnyInputChanged" />
                        </StackPanel>

                        <StackPanel x:Name="FabricFieldsPanel" Spacing="8" IsVisible="False">
                            <TextBlock Text="Connection String" Foreground="#4C6388" />
                            <TextBox x:Name="FabricConnectionStringTextBox"
                                     Height="96"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     TextChanged="OnAnyInputChanged" />
                        </StackPanel>

                        <StackPanel x:Name="BlobFieldsPanel" Spacing="8" IsVisible="False">
                            <TextBlock Text="Storage Account" Foreground="#4C6388" />
                            <TextBox x:Name="BlobStorageAccountTextBox"
                                     Height="36"
                                     IsReadOnly="True"
                                     TextChanged="OnAnyInputChanged" />
                            <TextBlock Text="Container" Foreground="#4C6388" />
                            <TextBox x:Name="BlobContainerTextBox"
                                     Height="36"
                                     IsReadOnly="True"
                                     TextChanged="OnAnyInputChanged" />
                            <TextBlock Text="Access Key" Foreground="#4C6388" />
                            <TextBox x:Name="BlobAccessKeyBox"
                                     Height="36"
                                     IsReadOnly="True"
                                     PasswordChar="*"
                                     TextChanged="OnAnyInputChanged" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <Grid Grid.Row="6"
                      ColumnDefinitions="*,8,Auto,8,Auto">
                    <TextBlock x:Name="StatusText"
                               VerticalAlignment="Center"
                               Foreground="#4C6388" />
                    <Button x:Name="CancelEditButton"
                            Grid.Column="2"
                            Content="Cancel"
                            Padding="12,6"
                            IsVisible="False"
                            Click="OnCancelEditClicked" />
                    <Button x:Name="SaveButton"
                            Grid.Column="4"
                            Content="Validate"
                            Padding="12,6"
                            IsVisible="False"
                            Background="#0B2D5C"
                            Foreground="White"
                            Click="OnSaveClicked" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
