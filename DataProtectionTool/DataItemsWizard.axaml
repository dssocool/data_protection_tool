<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="using:DataProtectionTool"
             mc:Ignorable="d"
             d:DesignWidth="980"
             d:DesignHeight="700"
             x:Class="DataProtectionTool.DataItemsWizard">
    <UserControl.Styles>
        <Style Selector="ListBox.entity-table-listbox">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Border.entity-table-row">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E0E8F2" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="ListBoxItem:selected Border.entity-table-row">
            <Setter Property="Background" Value="#DBE9FF" />
            <Setter Property="BorderBrush" Value="#4B78B1" />
        </Style>
        <Style Selector="Border.pill">
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Background" Value="#EEF3FB" />
            <Setter Property="BorderBrush" Value="#CBD8EA" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Button.pill-remove">
            <Setter Property="MinWidth" Value="18" />
            <Setter Property="MinHeight" Value="18" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Background" Value="#D9E5F6" />
            <Setter Property="BorderBrush" Value="#B2C7E3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </UserControl.Styles>

    <Grid x:Name="RootGrid"
          RowDefinitions="Auto,10,Auto,8,*"
          PointerPressed="OnRootPointerPressed">
        <Grid Grid.Row="0"
              ColumnDefinitions="190,Auto,*">
            <TextBlock Text="Data Items"
                       Grid.Column="0"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="#0B2D5C" />
            <Button Grid.Column="1"
                    Content="Add New"
                    Padding="12,6"
                    Click="OnAddNewClicked" />
        </Grid>

        <Border Grid.Row="2"
                Background="#0B2D5C"
                CornerRadius="8"
                Padding="16,10">
            <Grid ColumnDefinitions="1.2*,1.4*,2.2*"
                  ColumnSpacing="14">
                <TextBlock Text="Name"
                           Foreground="White"
                           FontWeight="SemiBold" />
                <TextBlock Grid.Column="1"
                           Text="Connections"
                           Foreground="White"
                           FontWeight="SemiBold" />
                <TextBlock Grid.Column="2"
                           Text="Items"
                           Foreground="White"
                           FontWeight="SemiBold" />
            </Grid>
        </Border>

        <Border Grid.Row="4"
                BorderBrush="#D7E1EF"
                BorderThickness="1"
                CornerRadius="10"
                Background="#F9FBFE"
                Padding="10">
            <Grid>
                <TextBlock x:Name="EmptyStateText"
                           Text="No data items yet. Click Add New to create one."
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#4C6388" />
                <ListBox x:Name="ItemsListBox"
                         Classes="entity-table-listbox"
                         IsVisible="False">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="local:DataItemRecord">
                            <Border Classes="entity-table-row"
                                    Margin="0,0,0,8"
                                    Padding="12,10"
                                    CornerRadius="6"
                                    PointerPressed="OnItemRowPressed">
                                <Grid ColumnDefinitions="1.2*,1.4*,2.2*"
                                      ColumnSpacing="14">
                                    <TextBlock Text="{Binding ItemName}" TextTrimming="CharacterEllipsis" />
                                    <ItemsControl Grid.Column="1" ItemsSource="{Binding ConnectionBadges}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="local:DataItemBadge">
                                                <Border Classes="pill"
                                                        Margin="0,0,6,6"
                                                        Background="{Binding Background}"
                                                        BorderBrush="{Binding Background}">
                                                    <TextBlock Text="{Binding Text}"
                                                               Foreground="{Binding Foreground}"
                                                               FontSize="11"
                                                               TextTrimming="CharacterEllipsis" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <ItemsControl Grid.Column="2" ItemsSource="{Binding ItemBadges}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="local:DataItemBadge">
                                                <Border Classes="pill"
                                                        Margin="0,0,6,6"
                                                        Background="{Binding Background}"
                                                        BorderBrush="{Binding Background}">
                                                    <TextBlock Text="{Binding Text}"
                                                               Foreground="{Binding Foreground}"
                                                               FontSize="11"
                                                               TextTrimming="CharacterEllipsis" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Border x:Name="DetailsPanel"
                Grid.RowSpan="5"
                HorizontalAlignment="Right"
                VerticalAlignment="Stretch"
                Width="620"
                Margin="0,0,10,0"
                ZIndex="10"
                BorderBrush="#D7E1EF"
                BorderThickness="1"
                CornerRadius="10"
                Background="White"
                Padding="14"
                IsVisible="False">
            <DockPanel LastChildFill="True">
                <Grid DockPanel.Dock="Top" ColumnDefinitions="*,8,Auto,8,Auto,8,Auto">
                    <TextBlock Text="Data Item Details"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#0B2D5C" />
                    <Button x:Name="EditButton"
                            Grid.Column="2"
                            Content="Edit"
                            Padding="10,4"
                            Click="OnEditClicked" />
                    <Button x:Name="CopyButton"
                            Grid.Column="4"
                            Content="Copy"
                            Padding="10,4"
                            Click="OnCopyClicked" />
                    <Button x:Name="DeleteButton"
                            Grid.Column="6"
                            Content="Delete"
                            Padding="10,4"
                            Click="OnDeleteClicked" />
                </Grid>

                <Grid DockPanel.Dock="Bottom"
                      Margin="0,12,0,0"
                      ColumnDefinitions="*,8,Auto,8,Auto">
                    <TextBlock x:Name="StatusText"
                               VerticalAlignment="Center"
                               Foreground="#4C6388"
                               TextWrapping="Wrap" />
                    <Button x:Name="CancelEditButton"
                            Grid.Column="2"
                            Content="Cancel"
                            Padding="12,6"
                            IsVisible="False"
                            Click="OnCancelEditClicked" />
                    <Button x:Name="SaveButton"
                            Grid.Column="4"
                            Content="Save"
                            Padding="12,6"
                            IsVisible="False"
                            Background="#0B2D5C"
                            Foreground="White"
                            Click="OnSaveClicked" />
                </Grid>

                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto"
                              Margin="0,12,0,0">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Name" Foreground="#4C6388" />
                        <TextBox x:Name="ItemNameTextBox"
                                 Height="36"
                                 IsReadOnly="True" />

                        <TextBlock Text="Connections" Foreground="#4C6388" />
                        <Grid ColumnDefinitions="*,8,Auto">
                            <Border x:Name="ConnectionPickerSurface"
                                    BorderBrush="#CBD8EA"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="8"
                                    PointerPressed="OnConnectionPickerPressed">
                                <StackPanel Spacing="6">
                                    <ItemsControl x:Name="SelectedConnectionsItemsControl">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="local:ConnectionChip">
                                                <Border Classes="pill" Margin="0,0,6,6">
                                                    <Grid ColumnDefinitions="Auto,6,Auto">
                                                        <TextBlock Text="{Binding Name}" />
                                                        <Button Grid.Column="2"
                                                                Classes="pill-remove"
                                                                Content="x"
                                                                Click="OnRemoveConnectionChipClicked" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBox x:Name="ConnectionSearchTextBox"
                                             Watermark="Search connections..."
                                             TextChanged="OnConnectionSearchTextChanged" />
                                </StackPanel>
                            </Border>
                            <Button x:Name="FetchButton"
                                    Grid.Column="2"
                                    Content="Fetch"
                                    Padding="12,6"
                                    Click="OnFetchClicked" />
                        </Grid>

                        <Border x:Name="ConnectionSuggestionsPopup"
                                IsVisible="False"
                                BorderBrush="#BFD0E7"
                                BorderThickness="1"
                                CornerRadius="8"
                                Background="White"
                                Padding="6"
                                MaxHeight="170">
                            <ListBox x:Name="ConnectionSuggestionsListBox"
                                     BorderThickness="0"
                                     Background="Transparent">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="local:ConnectionSuggestion">
                                        <Border Padding="8,6"
                                                PointerPressed="OnConnectionSuggestionPressed">
                                            <Grid ColumnDefinitions="1.4*,1.2*">
                                                <TextBlock Text="{Binding Name}" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Type}"
                                                           Foreground="#4C6388" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                        <StackPanel x:Name="PerConnectionPickersHost"
                                    Spacing="10"
                                    IsVisible="False">
                            <ItemsControl x:Name="PerConnectionPickersItemsControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="local:ConnectionItemsPickerModel">
                                        <Border BorderBrush="#CBD8EA"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="8">
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="{Binding ConnectionName}"
                                                           FontWeight="SemiBold"
                                                           Foreground="#244268" />

                                                <Border BorderBrush="#D7E1EF"
                                                        BorderThickness="1"
                                                        CornerRadius="8"
                                                        Padding="8"
                                                        PointerPressed="OnPerConnectionPickerPressed">
                                                    <StackPanel Spacing="6">
                                                        <ItemsControl ItemsSource="{Binding SelectedItems}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel Orientation="Horizontal" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate x:DataType="local:FetchedItemOption">
                                                                    <Border Classes="pill"
                                                                            Margin="0,0,6,6"
                                                                            Background="{Binding BadgeBackground}"
                                                                            BorderBrush="{Binding BadgeBackground}">
                                                                        <Grid ColumnDefinitions="Auto,6,Auto">
                                                                            <TextBlock Text="{Binding Name}"
                                                                                       Foreground="{Binding BadgeForeground}" />
                                                                            <Button Grid.Column="2"
                                                                                    Classes="pill-remove"
                                                                                    Content="x"
                                                                                    Click="OnRemovePerConnectionItemClicked" />
                                                                        </Grid>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        <TextBox Watermark="Search items..."
                                                                 Text="{Binding SearchText}"
                                                                 TextChanged="OnPerConnectionSearchTextChanged" />
                                                    </StackPanel>
                                                </Border>

                                                <Border IsVisible="{Binding IsSuggestionsVisible}"
                                                        BorderBrush="#BFD0E7"
                                                        BorderThickness="1"
                                                        CornerRadius="8"
                                                        Background="White"
                                                        Padding="4"
                                                        MaxHeight="150">
                                                    <ListBox ItemsSource="{Binding FilteredSuggestions}"
                                                             BorderThickness="0"
                                                             Background="Transparent">
                                                        <ListBox.ItemTemplate>
                                                            <DataTemplate x:DataType="local:FetchedItemOption">
                                                                <Border Padding="6"
                                                                        PointerPressed="OnPerConnectionSuggestionPressed">
                                                                    <Grid ColumnDefinitions="Auto,8,*">
                                                                        <Border Classes="pill"
                                                                                Background="{Binding BadgeBackground}"
                                                                                BorderBrush="{Binding BadgeBackground}">
                                                                            <TextBlock Text="{Binding KindLabel}"
                                                                                       FontSize="10"
                                                                                       Foreground="{Binding BadgeForeground}" />
                                                                        </Border>
                                                                        <TextBlock Grid.Column="2"
                                                                                   VerticalAlignment="Center"
                                                                                   Text="{Binding Name}" />
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ListBox.ItemTemplate>
                                                    </ListBox>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
