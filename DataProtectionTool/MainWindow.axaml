<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="using:DataProtectionTool"
        mc:Ignorable="d"
        d:DesignWidth="1100"
        d:DesignHeight="700"
        x:Class="DataProtectionTool.MainWindow"
        Title="Data Protection Tool"
        MinWidth="900"
        MinHeight="600"
        KeyDown="OnWindowKeyDown"
        Background="#F4F7FB">
    <Grid x:Name="RootLayoutGrid"
          Margin="24"
          ColumnSpacing="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="0" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0"
              RowDefinitions="Auto,16,Auto,12,*">
            <Grid ColumnDefinitions="Auto,12,*">
                <Button Grid.Column="0"
                        Content="+ New Flow"
                        Height="38"
                        MinWidth="140"
                        Padding="16,0"
                        CornerRadius="8"
                        FontWeight="SemiBold"
                        Background="#0B2D5C"
                        Foreground="White"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Click="OnNewFlowClicked"
                        HorizontalAlignment="Left" />

                <TextBox Grid.Column="2"
                         Height="38"
                         MinWidth="260"
                         Watermark="Search flows..."
                         HorizontalAlignment="Stretch" />
            </Grid>

            <Border Grid.Row="2"
                    Background="#0B2D5C"
                    CornerRadius="8"
                    Padding="16,12">
                <Grid ColumnDefinitions="2.6*,1.4*,1.4*,1.6*,1.1*,0.9*"
                      ColumnSpacing="16">
                    <TextBlock Grid.Column="0"
                               Text="Flow Name"
                               Foreground="White"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="1"
                               Text="Domain"
                               Foreground="White"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="2"
                               Text="Source"
                               Foreground="White"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="3"
                               Text="Destination"
                               Foreground="White"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="4"
                               Text="Status"
                               Foreground="White"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="5"
                               Text="Action"
                               Foreground="White"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                </Grid>
            </Border>

            <Border x:Name="FlowListContainer"
                    Grid.Row="4"
                    CornerRadius="8"
                    Background="#F9FBFE"
                    BorderBrush="#DCE5F2"
                    BorderThickness="1"
                    Padding="20"
                    PointerPressed="OnFlowListContainerPressed">
                <Grid>
                    <TextBlock x:Name="EmptyStateText"
                               Text="No flows yet. Click &quot;+ New Flow&quot; to create your first flow."
                               Foreground="#5E6A7D"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               FontSize="14" />

                    <ScrollViewer x:Name="FlowListScrollViewer"
                                  IsVisible="False"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="FlowListItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="local:FlowListItem">
                                    <Border Margin="0,0,0,10"
                                            Padding="12"
                                            CornerRadius="6"
                                            Background="White"
                                            BorderBrush="#E0E8F2"
                                            BorderThickness="1"
                                            PointerEntered="OnFlowRowPointerEntered"
                                            PointerPressed="OnFlowRowPointerPressed">
                                        <Grid ColumnDefinitions="2.6*,1.4*,1.4*,1.6*,1.1*,0.9*"
                                              ColumnSpacing="16">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding FlowName}"
                                                       Foreground="#21314A"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Domain}"
                                                       Foreground="#21314A"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Source}"
                                                       Foreground="#21314A"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding Destination}"
                                                       Foreground="#21314A"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="4"
                                                       Text="{Binding Status}"
                                                       Foreground="#21314A"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="5"
                                                       Text="{Binding Action}"
                                                       Foreground="#0B2D5C"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Canvas x:Name="FlowPopoverCanvas"
                            IsVisible="False"
                            ZIndex="10">
                        <Border x:Name="FlowHoverPopover"
                                Width="320"
                                Padding="14"
                                Background="White"
                                BorderBrush="#9DB3D1"
                                BorderThickness="1"
                                CornerRadius="8"
                                PointerPressed="OnPopoverPointerPressed">
                            <StackPanel Spacing="10">
                                <TextBlock x:Name="PopoverTitleText"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="#0B2D5C"
                                           TextTrimming="CharacterEllipsis" />

                                <Grid ColumnDefinitions="Auto,10,*"
                                      RowDefinitions="Auto,8,Auto,8,Auto,8,Auto">
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Text="Source"
                                               FontWeight="SemiBold"
                                               Foreground="#34445F" />
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="2"
                                               x:Name="PopoverSourceText"
                                               Foreground="#21314A"
                                               TextWrapping="Wrap" />

                                    <TextBlock Grid.Row="2"
                                               Grid.Column="0"
                                               Text="Destination"
                                               FontWeight="SemiBold"
                                               Foreground="#34445F" />
                                    <TextBlock Grid.Row="2"
                                               Grid.Column="2"
                                               x:Name="PopoverDestinationText"
                                               Foreground="#21314A"
                                               TextWrapping="Wrap" />

                                    <TextBlock Grid.Row="4"
                                               Grid.Column="0"
                                               Text="Data Items"
                                               FontWeight="SemiBold"
                                               Foreground="#34445F" />
                                    <TextBlock Grid.Row="4"
                                               Grid.Column="2"
                                               x:Name="PopoverDataItemsText"
                                               Foreground="#21314A"
                                               TextWrapping="Wrap" />

                                    <TextBlock Grid.Row="6"
                                               Grid.Column="0"
                                               Text="Data Rules"
                                               FontWeight="SemiBold"
                                               Foreground="#34445F" />
                                    <TextBlock Grid.Row="6"
                                               Grid.Column="2"
                                               x:Name="PopoverDataRulesText"
                                               Foreground="#21314A"
                                               TextWrapping="Wrap" />
                                </Grid>

                                <TextBlock x:Name="PopoverPinnedHintText"
                                           IsVisible="False"
                                           Text="Pinned. Press Esc or click blank area to unpin."
                                           Foreground="#4C6388"
                                           FontSize="12" />
                            </StackPanel>
                        </Border>
                    </Canvas>
                </Grid>
            </Border>
        </Grid>

        <Border x:Name="DetailsPanelHost"
                Grid.Column="1"
                IsVisible="False"
                Background="White"
                BorderBrush="#DCE5F2"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16">
            <local:FlowDetailsPanel x:Name="FlowDetailsPanelControl" />
        </Border>
    </Grid>
</Window>
