<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="using:DataProtectionTool"
        mc:Ignorable="d"
        d:DesignWidth="1100"
        d:DesignHeight="700"
        x:Class="DataProtectionTool.MainWindow"
        Title="Data Protection Tool"
        MinWidth="900"
        MinHeight="600"
        KeyDown="OnWindowKeyDown"
        Background="#F4F7FB">
    <Window.Styles>
        <Style Selector="Button.top-icon-button">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Background" Value="#EEF3FB" />
            <Setter Property="BorderBrush" Value="#CBD8EA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#0B2D5C" />
        </Style>
        <Style Selector="Border.flow-row">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E0E8F2" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Border.flow-row.hovered">
            <Setter Property="Background" Value="#ECF3FF" />
            <Setter Property="BorderBrush" Value="#6F96C7" />
        </Style>
        <Style Selector="Border.flow-row.selected">
            <Setter Property="Background" Value="#DBE9FF" />
            <Setter Property="BorderBrush" Value="#4B78B1" />
            <Setter Property="BorderThickness" Value="1.5" />
        </Style>
        <Style Selector="Button.wizard-nav-button">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Foreground" Value="#244268" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.wizard-nav-button.selected">
            <Setter Property="Background" Value="#E5EEFC" />
            <Setter Property="BorderBrush" Value="#AFC3E2" />
            <Setter Property="Foreground" Value="#0B2D5C" />
        </Style>
    </Window.Styles>

    <Grid x:Name="RootLayoutGrid"
          Margin="24">
        <Grid x:Name="MainListPage"
              RowDefinitions="Auto,16,Auto,12,*">
            <Grid ColumnDefinitions="*,12,Auto,8,Auto,8,Auto,12,Auto">
                <TextBox Grid.Column="0"
                         Height="38"
                         MinWidth="260"
                         Watermark="Search flows..."
                         HorizontalAlignment="Stretch" />

                <Button Grid.Column="2"
                        Classes="top-icon-button"
                        ToolTip.Tip="Connections"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <PathIcon Width="18"
                              Height="18"
                              Data="M5,4 A2,2 0 1 1 5,8 A2,2 0 1 1 5,4 M17,10 A2,2 0 1 1 17,14 A2,2 0 1 1 17,10 M5,16 A2,2 0 1 1 5,20 A2,2 0 1 1 5,16 M7,6 L15,12 M7,18 L15,12"
                              Foreground="#0B2D5C" />
                </Button>

                <Button Grid.Column="4"
                        Classes="top-icon-button"
                        ToolTip.Tip="Data Items"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <PathIcon Width="18"
                              Height="18"
                              Data="M4,5 L14,5 M4,10 L20,10 M4,15 L14,15 M4,20 L20,20 M16,5 L20,5 M16,15 L20,15"
                              Foreground="#0B2D5C" />
                </Button>

                <Button Grid.Column="6"
                        Classes="top-icon-button"
                        ToolTip.Tip="Data Rules"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <PathIcon Width="18"
                              Height="18"
                              Data="M6,5 L18,5 L18,9 L6,9 Z M8,9 L16,9 L16,14 L8,14 Z M10,14 L14,14 L14,19 L10,19 Z"
                              Foreground="#0B2D5C" />
                </Button>

                <Button Grid.Column="8"
                        Content="Create"
                        Height="38"
                        MinWidth="140"
                        Padding="16,0"
                        CornerRadius="8"
                        FontWeight="SemiBold"
                        Background="#0B2D5C"
                        Foreground="White"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Click="OnNewItemClicked"
                        HorizontalAlignment="Right" />
            </Grid>

            <Border Grid.Row="2"
                    Margin="60,0"
                    Background="#0B2D5C"
                    CornerRadius="8"
                    Padding="16,12">
                <Grid ColumnDefinitions="2.6*,1.4*,1.4*,1.6*,1.1*,0.9*"
                      ColumnSpacing="16">
                    <TextBlock Grid.Column="0"
                               Text="Flow Name"
                               Foreground="White"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="1"
                               Text="Domain"
                               Foreground="White"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="2"
                               Text="Source"
                               Foreground="White"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="3"
                               Text="Destination"
                               Foreground="White"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="4"
                               Text="Status"
                               Foreground="White"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="5"
                               Text="Action"
                               Foreground="White"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                </Grid>
            </Border>

            <Grid x:Name="FlowListContainer"
                  Grid.Row="4"
                  Margin="60,0"
                  PointerPressed="OnFlowListContainerPressed">
                <Grid>
                    <TextBlock x:Name="EmptyStateText"
                               Text="No flows yet. Click &quot;New Item&quot; to create your first flow."
                               Foreground="#5E6A7D"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               FontSize="14" />

                    <ScrollViewer x:Name="FlowListScrollViewer"
                                  IsVisible="False"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="FlowListItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="local:FlowListItem">
                                    <Border Margin="0,0,0,10"
                                            Classes="flow-row"
                                            MinHeight="52"
                                            Padding="16,12"
                                            CornerRadius="6"
                                            PointerEntered="OnFlowRowPointerEntered"
                                            PointerExited="OnFlowRowPointerExited"
                                            PointerPressed="OnFlowRowPointerPressed">
                                        <Grid ColumnDefinitions="2.6*,1.4*,1.4*,1.6*,1.1*,0.9*"
                                              ColumnSpacing="16">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding FlowName}"
                                                       Foreground="#21314A"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Domain}"
                                                       Foreground="#21314A"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Source}"
                                                       Foreground="#21314A"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding Destination}"
                                                       Foreground="#21314A"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="4"
                                                       Text="{Binding Status}"
                                                       Foreground="#21314A"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="5"
                                                       Text="{Binding Action}"
                                                       Foreground="#0B2D5C"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Canvas x:Name="FlowPopoverCanvas"
                            IsVisible="False"
                            ZIndex="10">
                        <Border x:Name="FlowHoverPopover"
                                Width="320"
                                Padding="14"
                                Background="White"
                                BorderBrush="#9DB3D1"
                                BorderThickness="1"
                                CornerRadius="8"
                                PointerEntered="OnPopoverPointerEntered"
                                PointerExited="OnPopoverPointerExited"
                                PointerPressed="OnPopoverPointerPressed">
                            <StackPanel Spacing="10">
                                <TextBlock x:Name="PopoverTitleText"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="#0B2D5C"
                                           TextTrimming="CharacterEllipsis" />

                                <Grid ColumnDefinitions="Auto,10,*"
                                      RowDefinitions="Auto,8,Auto,8,Auto,8,Auto">
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Text="Source"
                                               FontWeight="SemiBold"
                                               Foreground="#34445F" />
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="2"
                                               x:Name="PopoverSourceText"
                                               Foreground="#21314A"
                                               TextWrapping="Wrap" />

                                    <TextBlock Grid.Row="2"
                                               Grid.Column="0"
                                               Text="Destination"
                                               FontWeight="SemiBold"
                                               Foreground="#34445F" />
                                    <TextBlock Grid.Row="2"
                                               Grid.Column="2"
                                               x:Name="PopoverDestinationText"
                                               Foreground="#21314A"
                                               TextWrapping="Wrap" />

                                    <TextBlock Grid.Row="4"
                                               Grid.Column="0"
                                               Text="Data Items"
                                               FontWeight="SemiBold"
                                               Foreground="#34445F" />
                                    <TextBlock Grid.Row="4"
                                               Grid.Column="2"
                                               x:Name="PopoverDataItemsText"
                                               Foreground="#21314A"
                                               TextWrapping="Wrap" />

                                    <TextBlock Grid.Row="6"
                                               Grid.Column="0"
                                               Text="Data Rules"
                                               FontWeight="SemiBold"
                                               Foreground="#34445F" />
                                    <TextBlock Grid.Row="6"
                                               Grid.Column="2"
                                               x:Name="PopoverDataRulesText"
                                               Foreground="#21314A"
                                               TextWrapping="Wrap" />
                                </Grid>

                                <TextBlock x:Name="PopoverPinnedHintText"
                                           IsVisible="False"
                                           Text="Pinned. Press Esc or click blank area to unpin."
                                           Foreground="#4C6388"
                                           FontSize="12" />
                            </StackPanel>
                        </Border>
                    </Canvas>
                </Grid>
            </Grid>
        </Grid>

        <Grid x:Name="NewItemPage"
              IsVisible="False"
              RowDefinitions="Auto,16,*">
            <Grid ColumnDefinitions="Auto,12,*">
                <Button Grid.Column="0"
                        Content="Back"
                        Width="96"
                        Height="36"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Click="OnBackToMainClicked" />
                <TextBlock Grid.Column="2"
                           VerticalAlignment="Center"
                           Text="New Item Workspace"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="#0B2D5C" />
            </Grid>

            <Grid Grid.Row="2"
                  ColumnDefinitions="220,16,*">
                <Border Grid.Column="0"
                        Background="White"
                        BorderBrush="#D7E1EF"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="10">
                    <StackPanel Spacing="6">
                        <Button x:Name="NavMainListButton"
                                Classes="wizard-nav-button"
                                Content="Main/List"
                                Click="OnMainListNavClicked" />
                        <Button x:Name="NavFlowsButton"
                                Classes="wizard-nav-button selected"
                                Content="Flows"
                                Click="OnFlowsNavClicked" />
                        <Button x:Name="NavConnectionsButton"
                                Classes="wizard-nav-button"
                                Content="Connections"
                                Click="OnConnectionsNavClicked" />
                        <Button x:Name="NavDataItemsButton"
                                Classes="wizard-nav-button"
                                Content="Data Items"
                                Click="OnDataItemsNavClicked" />
                        <Button x:Name="NavDataRulesButton"
                                Classes="wizard-nav-button"
                                Content="Data Rules"
                                Click="OnDataRulesNavClicked" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Background="#F9FBFE"
                        BorderBrush="#D7E1EF"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="16">
                    <ContentControl x:Name="WizardContentHost" />
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
