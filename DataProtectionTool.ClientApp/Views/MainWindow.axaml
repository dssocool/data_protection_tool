<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="using:DataProtectionTool.ClientApp.Models"
        mc:Ignorable="d"
        d:DesignWidth="1100"
        d:DesignHeight="700"
        x:Class="DataProtectionTool.ClientApp.Views.MainWindow"
        Title="Data Protection Tool"
        MinWidth="900"
        MinHeight="600"
        KeyDown="OnWindowKeyDown"
        Background="#F4F7FB">
    <Window.Styles>
        <Style Selector="Button.top-icon-button">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Background" Value="#EEF3FB" />
            <Setter Property="BorderBrush" Value="#CBD8EA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#0B2D5C" />
        </Style>
        <Style Selector="Border.flow-row">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E0E8F2" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Border.flow-row.hovered">
            <Setter Property="Background" Value="#ECF3FF" />
            <Setter Property="BorderBrush" Value="#6F96C7" />
        </Style>
        <Style Selector="Border.flow-row.selected">
            <Setter Property="Background" Value="#DBE9FF" />
            <Setter Property="BorderBrush" Value="#4B78B1" />
            <Setter Property="BorderThickness" Value="1.5" />
        </Style>
        <Style Selector="Button.wizard-nav-icon-button">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#244268" />
        </Style>
        <Style Selector="Button.wizard-nav-icon-button.selected">
            <Setter Property="Background" Value="#E5EEFC" />
            <Setter Property="BorderBrush" Value="#AFC3E2" />
            <Setter Property="Foreground" Value="#0B2D5C" />
        </Style>
    </Window.Styles>

    <Grid x:Name="RootLayoutGrid"
          Margin="24">
        <Grid x:Name="MainListPage"
              RowDefinitions="*">
            <Grid
                  ColumnDefinitions="74,16,*">
                <Border Grid.Column="0"
                        Background="White"
                        BorderBrush="#D7E1EF"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="8">
                    <StackPanel Spacing="8"
                                HorizontalAlignment="Center">
                        <Button x:Name="MainNavMainListButton"
                                Classes="wizard-nav-icon-button selected"
                                ToolTip.Tip="go to configuration workspace"
                                Click="OnGoToConfigurationWorkspaceClicked">
                            <TextBlock Text="Edit"
                                       FontSize="14"
                                       FontWeight="SemiBold" />
                        </Button>
                        <Button x:Name="MainNavFlowsButton"
                                Classes="wizard-nav-icon-button"
                                ToolTip.Tip="Flows"
                                Click="OnFlowsNavClicked">
                            <Image Width="28"
                                   Height="28"
                                   Source="{SvgImage /Assets/flow.svg}" />
                        </Button>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Background="#F9FBFE"
                        BorderBrush="#D7E1EF"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="16">
                    <Grid RowDefinitions="Auto,16,Auto,12,*">
                        <TextBox Height="38"
                                 MinWidth="260"
                                 Watermark="Search flows..."
                                 HorizontalAlignment="Stretch" />

                        <Border Grid.Row="2"
                                Background="#0B2D5C"
                                CornerRadius="8"
                                Padding="16,12">
                            <Grid ColumnDefinitions="2.8*,1.5*,1.5*,1.7*,1.2*"
                                  ColumnSpacing="16">
                                <TextBlock Grid.Column="0"
                                           Text="Flow Name"
                                           Foreground="White"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="1"
                                           Text="Domain"
                                           Foreground="White"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="2"
                                           Text="Source"
                                           Foreground="White"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="3"
                                           Text="Destination"
                                           Foreground="White"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="4"
                                           Text="Status"
                                           Foreground="White"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="4"
                                Background="White"
                                BorderBrush="#D7E1EF"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="12">
                            <Grid x:Name="FlowListContainer"
                                  PointerPressed="OnFlowListContainerPressed">
                                <Grid>
                                    <Button x:Name="EmptyStateAddFlowButton"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            BorderThickness="0"
                                            Padding="24"
                                            Click="OnEmptyStateAddFlowClicked">
                                        <StackPanel Spacing="4"
                                                    HorizontalAlignment="Center">
                                            <TextBlock Text="+"
                                                       FontSize="120"
                                                       FontWeight="Light"
                                                       Foreground="#8CA4C5"
                                                       Opacity="0.45"
                                                       HorizontalAlignment="Center" />
                                            <TextBlock Text="Click to add new flow ..."
                                                       Foreground="#5E6A7D"
                                                       HorizontalAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       FontSize="16" />
                                        </StackPanel>
                                    </Button>

                                    <ScrollViewer x:Name="FlowListScrollViewer"
                                                  IsVisible="False"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsControl x:Name="FlowListItemsControl">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="models:FlowListItem">
                                                    <Border Margin="0,0,0,10"
                                                            Classes="flow-row"
                                                            MinHeight="52"
                                                            Padding="16,12"
                                                            CornerRadius="6"
                                                            PointerEntered="OnFlowRowPointerEntered"
                                                            PointerExited="OnFlowRowPointerExited"
                                                            PointerPressed="OnFlowRowPointerPressed">
                                                        <Grid ColumnDefinitions="2.8*,1.5*,1.5*,1.7*,1.2*"
                                                              ColumnSpacing="16">
                                                            <TextBlock Grid.Column="0"
                                                                       Text="{Binding FlowName}"
                                                                       Foreground="#21314A"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding Domain}"
                                                                       Foreground="#21314A"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Grid.Column="2"
                                                                       Text="{Binding Source}"
                                                                       Foreground="#21314A"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Grid.Column="3"
                                                                       Text="{Binding Destination}"
                                                                       Foreground="#21314A"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Grid.Column="4"
                                                                       Text="{Binding Status}"
                                                                       Foreground="#21314A"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <Canvas x:Name="FlowPopoverCanvas"
                                            IsVisible="False"
                                            ZIndex="10">
                                        <Border x:Name="FlowHoverPopover"
                                                Width="320"
                                                Padding="14"
                                                Background="White"
                                                BorderBrush="#9DB3D1"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                PointerEntered="OnPopoverPointerEntered"
                                                PointerExited="OnPopoverPointerExited"
                                                PointerPressed="OnPopoverPointerPressed">
                                            <StackPanel Spacing="10">
                                                <TextBlock x:Name="PopoverTitleText"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Foreground="#0B2D5C"
                                                           TextTrimming="CharacterEllipsis" />

                                                <Grid ColumnDefinitions="Auto,10,*"
                                                      RowDefinitions="Auto,8,Auto,8,Auto,8,Auto">
                                                    <TextBlock Grid.Row="0"
                                                               Grid.Column="0"
                                                               Text="Source"
                                                               FontWeight="SemiBold"
                                                               Foreground="#34445F" />
                                                    <TextBlock Grid.Row="0"
                                                               Grid.Column="2"
                                                               x:Name="PopoverSourceText"
                                                               Foreground="#21314A"
                                                               TextWrapping="Wrap" />

                                                    <TextBlock Grid.Row="2"
                                                               Grid.Column="0"
                                                               Text="Destination"
                                                               FontWeight="SemiBold"
                                                               Foreground="#34445F" />
                                                    <TextBlock Grid.Row="2"
                                                               Grid.Column="2"
                                                               x:Name="PopoverDestinationText"
                                                               Foreground="#21314A"
                                                               TextWrapping="Wrap" />

                                                    <TextBlock Grid.Row="4"
                                                               Grid.Column="0"
                                                               Text="Data Items"
                                                               FontWeight="SemiBold"
                                                               Foreground="#34445F" />
                                                    <TextBlock Grid.Row="4"
                                                               Grid.Column="2"
                                                               x:Name="PopoverDataItemsText"
                                                               Foreground="#21314A"
                                                               TextWrapping="Wrap" />

                                                    <TextBlock Grid.Row="6"
                                                               Grid.Column="0"
                                                               Text="Data Rules"
                                                               FontWeight="SemiBold"
                                                               Foreground="#34445F" />
                                                    <TextBlock Grid.Row="6"
                                                               Grid.Column="2"
                                                               x:Name="PopoverDataRulesText"
                                                               Foreground="#21314A"
                                                               TextWrapping="Wrap" />
                                                </Grid>

                                                <TextBlock x:Name="PopoverPinnedHintText"
                                                           IsVisible="False"
                                                           Text="Pinned. Press Esc or click blank area to unpin."
                                                           Foreground="#4C6388"
                                                           FontSize="12" />
                                            </StackPanel>
                                        </Border>
                                    </Canvas>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Grid x:Name="NewItemPage"
              IsVisible="False"
              RowDefinitions="*">
            <Grid
                  ColumnDefinitions="74,16,*">
                <Border Grid.Column="0"
                        Background="White"
                        BorderBrush="#D7E1EF"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="8">
                    <StackPanel Spacing="8"
                                HorizontalAlignment="Center">
                        <Button x:Name="NavMainListButton"
                                Classes="wizard-nav-icon-button"
                                ToolTip.Tip="go to execution workspace"
                                Click="OnMainListNavClicked">
                            <TextBlock Text="Run"
                                       FontSize="14"
                                       FontWeight="SemiBold" />
                        </Button>
                        <Button x:Name="NavFlowsButton"
                                Classes="wizard-nav-icon-button selected"
                                ToolTip.Tip="Flows"
                                Click="OnFlowsNavClicked">
                            <Image Width="28"
                                   Height="28"
                                   Source="{SvgImage /Assets/flow_in_edit.svg}" />
                        </Button>
                        <Button x:Name="NavConnectionsButton"
                                Classes="wizard-nav-icon-button"
                                ToolTip.Tip="Connections"
                                Click="OnConnectionsNavClicked">
                            <Image Width="28"
                                   Height="28"
                                   Source="{SvgImage /Assets/connection.svg}" />
                        </Button>
                        <Button x:Name="NavDataItemsButton"
                                Classes="wizard-nav-icon-button"
                                ToolTip.Tip="Data Items"
                                Click="OnDataItemsNavClicked">
                            <Image Width="28"
                                   Height="28"
                                   Source="{SvgImage /Assets/data_item.svg}" />
                        </Button>
                        <Button x:Name="NavDataRulesButton"
                                Classes="wizard-nav-icon-button"
                                ToolTip.Tip="Data Rules"
                                Click="OnDataRulesNavClicked">
                            <Image Width="28"
                                   Height="28"
                                   Source="{SvgImage /Assets/data_rule.svg}" />
                        </Button>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Background="#F9FBFE"
                        BorderBrush="#D7E1EF"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="16">
                    <ContentControl x:Name="WizardContentHost" />
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
